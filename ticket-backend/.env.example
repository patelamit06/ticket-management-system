# Database (schema is env-based: set DB_SCHEMA per environment)
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/ticket_db"
DB_SCHEMA=ticket_db

# Server
PORT=3001
FRONTEND_URL=http://localhost:3000

# JWT (use: openssl rand -base64 32)
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES=15m

# Stripe (test keys from https://dashboard.stripe.com/test/apikeys)
STRIPE_SECRET_KEY=sk_test_YOUR_STRIPE_SECRET_KEY
STRIPE_WEBHOOK_SECRET=whsec_YOUR_STRIPE_WEBHOOK_SECRET

# Object storage = AWS S3 (event media). The browser uploads via presigned PUT
# and reads from S3. Leave unset to disable uploads in local dev.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=
S3_REGION=us-east-1
# Public base URL the browser uses to display media (defaults to the
# virtual-hosted S3 URL: https://<bucket>.s3.<region>.amazonaws.com).
# S3_PUBLIC_URL=
# Optional: custom endpoint for S3-compatible providers (omit for AWS S3).
# S3_ENDPOINT=

# Email notifications (SMTP) — welcome, password reset, order confirmation.
# Defaults target Gmail; for Gmail use an App Password (https://myaccount.google.com/apppasswords),
# not your account password. If SMTP_* are unset, emails are logged to the console (fine for local dev).
APP_NAME=Tikitlo
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password
MAIL_FROM="Your App <your@gmail.com>"

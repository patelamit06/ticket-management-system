# Database (schema is env-based: set DB_SCHEMA per environment)
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/ticket_db"
DB_SCHEMA=ticket_db

# Server
PORT=3001
FRONTEND_URL=http://localhost:3000

# JWT (use: openssl rand -base64 32)
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES=15m

# Stripe (test keys from https://dashboard.stripe.com/test/apikeys)
STRIPE_SECRET_KEY=sk_test_YOUR_STRIPE_SECRET_KEY
STRIPE_WEBHOOK_SECRET=whsec_YOUR_STRIPE_WEBHOOK_SECRET

# Optional: Email (SendGrid or Resend)
# SENDGRID_API_KEY=
# RESEND_API_KEY=

# Swish (Swedish mobile payment)
SWISH_BASE_URL=https://staging.getswish.pub.tds.tieto.com/swish-cpcapi/api/v2/paymentrequests/
SWISH_MERCHANT_NUMBER=your_merchant_number
# PEM cert+key OR a .p12 bundle (set SWISH_CERT_PATH to the .p12 and leave SWISH_KEY_PATH empty)
SWISH_CERT_PATH=C:\Users\dev001\repos\ticket-management-system\CertificatePath\myCertificate.p12
SWISH_KEY_PATH=
SWISH_CA_PATH=C:\Users\dev001\repos\ticket-management-system\CertificatePath\SANDBOX_Swish_TLS_RootCA.pem
SWISH_PASSPHRASE=swish
SWISH_CALLBACK_URL=https://your-ngrok-or-domain.app/api/swish/callback

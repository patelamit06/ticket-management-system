// Event Management & Ticketing - Prisma schema (Prisma 7)
// Uses schema "ticket_db" (must match DB_SCHEMA in .env). Run: npx prisma generate && npx prisma migrate dev

generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
  schemas  = ["ticket_db"]
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  name         String?
  phone        String?
  role         String   // super_admin | organizer | coordinator | attendee
  country      String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  organizedEvents Event[]

  @@map("users")
  @@schema("ticket_db")
}

/// Master table: phone dial codes for signup; optional isoCode for browse/locale (e.g. US, GB).
model Country {
  id        String   @id @default(cuid())
  dialCode  String   @unique @map("dial_code")   // e.g. "+91"
  name      String   @map("name")                // e.g. "India"
  isoCode   String?  @unique @map("iso_code")    // e.g. "IN" for browse/locale; null = phone only
  sortOrder Int      @default(0) @map("sort_order")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("country")
  @@schema("ticket_db")
}

/// Event: organizerId = owner (user who created it). status: draft | pending_approval | published | cancelled.
model Event {
  id          String    @id @default(cuid())
  name        String
  description String?   @db.Text
  location    String?
  startDate   DateTime  @map("start_date")
  endDate     DateTime  @map("end_date")
  bannerUrl   String?   @map("banner_url")
  status      String    @default("draft") // draft | pending_approval | published | cancelled
  organizerId String    @map("organizer_id")
  country     String?   // ISO code e.g. US, IN (for filtering)
  city        String?
  timezone    String?
  /// Quantity-based discount tiers applied at order level: [{ "maxQuantity": 5, "discountPercent": 5 }, ...]
  groupDiscountTiers Json?   @map("group_discount_tiers")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  organizer    User           @relation(fields: [organizerId], references: [id], onDelete: Cascade)
  ticketTypes  TicketType[]
  discounts    EventDiscount[]

  @@map("events")
  @@schema("ticket_db")
}

/// Ticket type = fixed price (or free) product. No discount logic here; use EventDiscount for that.
model TicketType {
  id                String    @id @default(cuid())
  eventId           String    @map("event_id")
  name              String    // e.g. "Adult", "Kids 5-12"
  price             Decimal   @db.Decimal(10, 2)
  quantity          Int       @default(0)   // max capacity (0 = unlimited)
  maxPerOrder       Int       @default(10)  // 1-20
  availabilityStart DateTime? @map("availability_start")
  availabilityEnd   DateTime? @map("availability_end")
  ageMin            Int?      @map("age_min")
  ageMax            Int?      @map("age_max")
  sortOrder         Int       @default(0) @map("sort_order")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@map("ticket_types")
  @@schema("ticket_db")
}

/// Discount type (e.g. Early bird %, Group quantity discount). Applies to ticket types at checkout.
model EventDiscount {
  id              String    @id @default(cuid())
  eventId         String    @map("event_id")
  name            String    // e.g. "Early Bird", "Group 10+"
  type            String    // early_bird | group
  discountPercent Decimal   @map("discount_percent") @db.Decimal(5, 2)
  /// early_bird: valid until this date (inclusive)
  validTo         DateTime? @map("valid_to")
  /// group: minimum quantity in order to get this discount
  minQuantity     Int?      @map("min_quantity")
  /// Optional: apply only to these ticket type ids (JSON array). null = all ticket types
  ticketTypeIds   Json?     @map("ticket_type_ids")
  sortOrder       Int       @default(0) @map("sort_order")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@map("event_discounts")
  @@schema("ticket_db")
}

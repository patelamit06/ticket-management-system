// Event Management & Ticketing - Prisma schema (Prisma 7)
// Uses schema "ticket_db" (must match DB_SCHEMA in .env). Run: npx prisma generate && npx prisma migrate dev

generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
  schemas  = ["ticket_db"]
}

model User {
  id                     String   @id @default(cuid())
  email                  String   @unique
  passwordHash           String   @map("password_hash")
  name                   String?
  phone                  String?
  role                   String   // super_admin | organizer | coordinator | attendee
  country                String?
  stripeConnectAccountId String?  @map("stripe_connect_account_id") // For payouts (Stripe Connect)
  createdAt              DateTime @default(now()) @map("created_at")
  updatedAt              DateTime @updatedAt @map("updated_at")

  organizedEvents Event[]
  orders         Order[]

  @@map("users")
  @@schema("ticket_db")
}

/// Master table: phone dial codes for signup; optional isoCode for browse/locale (e.g. US, GB).
model Country {
  id        String   @id @default(cuid())
  dialCode  String   @unique @map("dial_code")   // e.g. "+91"
  name      String   @map("name")                // e.g. "India"
  isoCode   String?  @unique @map("iso_code")    // e.g. "IN" for browse/locale; null = phone only
  sortOrder Int      @default(0) @map("sort_order")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("country")
  @@schema("ticket_db")
}

/// Event: organizerId = owner (user who created it). status: draft | pending_approval | published | cancelled.
model Event {
  id          String    @id @default(cuid())
  name        String
  description String?   @db.Text
  location    String?
  startDate   DateTime  @map("start_date")
  endDate     DateTime  @map("end_date")
  bannerUrl   String?   @map("banner_url")
  status      String    @default("draft") // draft | pending_approval | published | cancelled
  organizerId String    @map("organizer_id")
  country     String?   // ISO code e.g. US, IN (for filtering)
  city        String?
  timezone    String?
  /// Quantity-based discount tiers applied at order level: [{ "maxQuantity": 5, "discountPercent": 5 }, ...]
  groupDiscountTiers Json?   @map("group_discount_tiers")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  organizer    User           @relation(fields: [organizerId], references: [id], onDelete: Cascade)
  ticketTypes  TicketType[]
  discounts    EventDiscount[]
  media        EventMedia[]
  orders       Order[]

  @@map("events")
  @@schema("ticket_db")
}

/// Event media for carousel: images (stored in MinIO) or video links (e.g. YouTube).
model EventMedia {
  id        String   @id @default(cuid())
  eventId   String   @map("event_id")
  type      String   // image | video
  url       String   // MinIO object URL for image; embed or watch URL for video
  caption   String?  @db.VarChar(500)
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@map("event_media")
  @@schema("ticket_db")
}

/// Ticket type = fixed price (or free) product. No discount logic here; use EventDiscount for that.
model TicketType {
  id                String    @id @default(cuid())
  eventId           String    @map("event_id")
  name              String    // e.g. "Adult", "Kids 5-12"
  price             Decimal   @db.Decimal(10, 2)
  quantity          Int       @default(0)   // max capacity (0 = unlimited)
  maxPerOrder       Int       @default(10)  // 1-20
  isActive          Boolean   @default(true) @map("is_active")
  availabilityStart DateTime? @map("availability_start")
  availabilityEnd   DateTime? @map("availability_end")
  ageMin            Int?      @map("age_min")
  ageMax            Int?      @map("age_max")
  sortOrder         Int       @default(0) @map("sort_order")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  event      Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]

  @@map("ticket_types")
  @@schema("ticket_db")
}

/// Discount type (e.g. Early bird %, Group quantity discount). Applies to ticket types at checkout.
model EventDiscount {
  id              String    @id @default(cuid())
  eventId         String    @map("event_id")
  name            String    // e.g. "Early Bird", "Group 10+"
  type            String    // early_bird | group
  discountPercent Decimal   @map("discount_percent") @db.Decimal(5, 2)
  isActive        Boolean   @default(true) @map("is_active")
  /// early_bird: valid until this date (inclusive)
  validTo         DateTime? @map("valid_to")
  /// group: minimum quantity in order to get this discount
  minQuantity     Int?      @map("min_quantity")
  /// Optional: apply only to these ticket type ids (JSON array). null = all ticket types
  ticketTypeIds   Json?     @map("ticket_type_ids")
  sortOrder       Int       @default(0) @map("sort_order")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@map("event_discounts")
  @@schema("ticket_db")
}

/// Order: one per checkout (one event per order in v1). status: pending | paid | cancelled | expired.
model Order {
  id                      String    @id @default(cuid())
  userId                  String?   @map("user_id")
  eventId                 String    @map("event_id")
  status                  String    @default("pending") // pending | paid | cancelled | expired
  totalAmount             Decimal   @map("total_amount") @db.Decimal(10, 2)
  currency                String    @default("USD") @db.VarChar(3)
  stripePaymentIntentId   String?   @unique @map("stripe_payment_intent_id")
  guestEmail              String?   @map("guest_email")
  guestName               String?   @map("guest_name")
  taxAmount               Decimal?  @map("tax_amount") @db.Decimal(10, 2)
  taxCountry              String?   @map("tax_country") @db.VarChar(2)
  applicationFeeAmount    Decimal?  @map("application_fee_amount") @db.Decimal(10, 2) // Platform fee (e.g. 5%)
  createdAt               DateTime  @default(now()) @map("created_at")
  updatedAt               DateTime  @updatedAt @map("updated_at")

  user   User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  event  Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  items  OrderItem[]

  @@map("orders")
  @@schema("ticket_db")
}

/// Line item: ticket type + quantity and price at purchase.
model OrderItem {
  id              String   @id @default(cuid())
  orderId         String   @map("order_id")
  ticketTypeId    String   @map("ticket_type_id")
  quantity        Int
  priceAtPurchase Decimal  @map("price_at_purchase") @db.Decimal(10, 2)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  ticketType   TicketType @relation(fields: [ticketTypeId], references: [id], onDelete: Cascade)
  tickets      Ticket[]

  @@map("order_items")
  @@schema("ticket_db")
}

/// Issued ticket (one per quantity per OrderItem). Created on payment success.
model Ticket {
  id          String    @id @default(cuid())
  orderItemId String    @map("order_item_id")
  uniqueCode  String    @unique @map("unique_code")
  usedAt      DateTime? @map("used_at") // Check-in time
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  orderItem OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  @@map("tickets")
  @@schema("ticket_db")
}
